# Terraform local state files
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Keep bootstrap state — it tracks the state-backend container itself.
# If you lose this file you lose track of the PostgreSQL container.
!bootstrap/terraform.tfstate

# Terraform provider plugins (downloaded on `terraform init`)
.terraform/
terraform.tfstate
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Variable override files (may contain secrets)
*.tfvars
!*.tfvars.example

# CLI configuration
.terraformrc
terraform.rc
